{
  "manifest_version": 3,
  "name": "CyberPlayer — Media Detector & Player",
  "version": "1.0.0",
  "description": "Cyberpunk media detector: finds the real videos on any page (not ads) and plays them right inside the extension — direct files plus HLS streams. No downloads.",
  "permissions": [
    "webRequest",
    "webNavigation",
    "storage",
    "scripting",
    "tabs"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "CyberPlayer",
    "default_icon": {
      "32": "icons/icon32.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "32": "icons/icon32.png",
    "128": "icons/icon128.png",
    "256": "icons/icon256.png"
  }
}
