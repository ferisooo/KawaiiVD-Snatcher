{
  "manifest_version": 3,
  "name": "CyberSnatcher — Media Snatcher",
  "version": "1.2.0",
  "description": "Cyberpunk media snatcher: detects videos on any page and downloads them — direct files plus full HLS stream merging (clear & AES-128). Filters out ads and stream fragments. No DRM.",
  "permissions": [
    "downloads",
    "webRequest",
    "webNavigation",
    "storage",
    "scripting",
    "offscreen",
    "notifications",
    "tabs"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "CyberSnatcher",
    "default_icon": {
      "32": "icons/icon32.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "32": "icons/icon32.png",
    "128": "icons/icon128.png",
    "256": "icons/icon256.png"
  }
}
